NODE_ENV=development
PORT=3001

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your_publishable_key

DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-1-ap-south-1.pooler.supabase.com:5432/postgres?sslmode=require

JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=12h
PDF_OUTPUT_DIR=tmp/pdfs
LOG_LEVEL=info
SLOW_QUERY_THRESHOLD_MS=180
IMPORT_TX_TIMEOUT_MS=60000
IMPORT_TX_MAX_WAIT_MS=10000
