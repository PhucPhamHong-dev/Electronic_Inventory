{
  "name": "wms-enterprise-backend-nest",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/backend/src/main.js",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
